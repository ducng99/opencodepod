{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "hostname": "0.0.0.0",
    "port": 8080,
    "cors": ["*"],
  },
  "instructions": [
    "https://raw.githubusercontent.com/ducng99/opencodepod/refs/heads/main/docker/AGENTS.md",
    ".rules",
    "AGENT.md",
    ".cursorrules",
    "CLAUDE.md",
    "GEMINI.md",
  ],
  "agent": {
    "build": {
      "permission": {
        "mkdir *": "allow",
        "npm run lint*": "allow",
        "pnpm run lint*": "allow",
        "bun run lint*": "allow",
        "npm run build*": "allow",
        "pnpm run build*": "allow",
        "bun run build*": "allow",
        "tsc *": "allow",
        "go build *": "allow",
        "go mod init *": "allow",
        "go generate *": "allow",
        "gofmt *": "allow",
        "gofumpt *": "allow",
        "eslint *": "allow",
        "prettier *": "allow",
        "touch *": "allow",
      },
    },
  },
  "permission": {
    "bash": {
      "ls *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "sort *": "allow",
      "wc *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "go mod verify": "allow",
      "go mod why *": "allow",
      "go doc *": "allow",
    },
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "vendor/**"],
  },
}
