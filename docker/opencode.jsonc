{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "https://raw.githubusercontent.com/ducng99/opencodepod/refs/heads/main/docker/AGENTS.md",
    ".rules",
    "AGENT.md",
    ".cursorrules",
    "CLAUDE.md",
    "GEMINI.md",
  ],
  "shell": "/bin/zsh",
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "*": "ask",
          "mkdir *": "allow",
          "npm run lint*": "allow",
          "pnpm run lint*": "allow",
          "bun run lint*": "allow",
          "npm run build*": "allow",
          "pnpm run build*": "allow",
          "bun run build*": "allow",
          "npm run test*": "allow",
          "pnpm run test*": "allow",
          "bun run test*": "allow",
          "bun test *": "allow",
          "tsc *": "allow",
          "go build *": "allow",
          "go mod init *": "allow",
          "go generate *": "allow",
          "go test *": "allow",
          "gofmt *": "allow",
          "gofumpt *": "allow",
          "eslint *": "allow",
          "prettier *": "allow",
          "touch *": "allow",
        },
      },
    },
  },
  "permission": {
    "bash": {
      "npm ls *": "allow",
      "pnpm ls *": "allow",
      "npm view *": "allow",
      "pnpm view *": "allow",
      "npm info *": "allow",
      "pnpm info *": "allow",
      "bun info *": "allow",
      "npm explain": "allow",
      "pnpm explain *": "allow",
      "bun why *": "allow",
      "ls *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "sort *": "allow",
      "wc *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "go mod verify": "allow",
      "go mod why *": "allow",
      "go doc *": "allow",
    },
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "vendor/**"],
  },
}
